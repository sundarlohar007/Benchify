# =============================================================================
# Benchify (PerformanceBench) Server — Environment Configuration
# =============================================================================
# Copy to .env and customize for your deployment.
# In production, JWT_SECRET and DATABASE_URL should NEVER use default values.
#
# Deployment modes:
#   Development:  cargo run (reads .env from project root)
#   Docker:       docker compose uses env vars from this file
#   Bare metal:   /opt/benchify/.env (created by deploy/install.sh)
# =============================================================================

# Development settings (localhost)
HOST=0.0.0.0
PORT=3000

# Database (change password in production!)
DATABASE_URL=postgres://benchify:benchify@localhost:5432/benchify

# JWT secret — change to a strong random value in production
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-uuid

# ── TLS (optional — use nginx reverse proxy in production) ──
# Direct TLS with built-in rustls server:
# TLS_CERT_PATH=/etc/letsencrypt/live/benchify.example.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/benchify.example.com/privkey.pem

# ── SSO (Enterprise) Configuration ──
# SSO_ENABLED=false
# SSO_REDIRECT_BASE_URL=https://benchify.example.com

# OIDC providers via config file (optional — DB configs take precedence)
# OIDC_PROVIDERS__0__NAME=google
# OIDC_PROVIDERS__0__CLIENT_ID=your-client-id.apps.googleusercontent.com
# OIDC_PROVIDERS__0__CLIENT_SECRET=your-client-secret
# OIDC_PROVIDERS__0__ISSUER_URL=https://accounts.google.com
# OIDC_PROVIDERS__0__SCOPES__0=openid
# OIDC_PROVIDERS__0__SCOPES__1=profile
# OIDC_PROVIDERS__0__SCOPES__2=email
# OIDC_PROVIDERS__0__ATTRIBUTE_MAPPING__EMAIL=email
# OIDC_PROVIDERS__0__ATTRIBUTE_MAPPING__DISPLAY_NAME=name

# TLS (optional)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
