# =============================================================================
# Benchify (PerformanceBench) Server — Environment Configuration
# =============================================================================
# *** SECURITY WARNING ***
# Do not commit this file with real secrets to version control.
# Copy to .env and customize for your deployment.
# Add .env to your .gitignore file.
# =============================================================================
#
# Deployment modes:
#   Development:  cargo run (reads .env from project root)
#   Docker:       docker compose uses env vars from this file
#   Bare metal:   /opt/benchify/.env (created by deploy/install.sh)
#   Kubernetes:   Configure via Helm values.yaml secrets
#
# Generate strong secrets:
#   openssl rand -hex 32   # JWT secret, API keys
#   openssl rand -base64 32 # Database passwords
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER — Required
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Host address. Use 0.0.0.0 to bind all interfaces.
HOST=0.0.0.0

# [REQUIRED] HTTP port. Change if port 3000 is in use.
PORT=3000

# Upload directory for session files (.pbz archives).
UPLOAD_DIR=./uploads

# CORS allowed origins (comma-separated in production, use specific domains).
# In production, restrict to your dashboard domain(s).
# CORS_ALLOWED_ORIGINS__0=https://benchify.example.com
# CORS_ALLOWED_ORIGINS__1=https://dashboard.example.com

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE — Required
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] PostgreSQL connection URL.
# Format: postgres://user:password@host:port/database
# WARNING: Change the default password in production!
DATABASE_URL=postgres://benchify:benchify@localhost:5432/benchify

# ═══════════════════════════════════════════════════════════════════════════════
# AUTH — Required
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] JWT signing secret. Auto-generated UUID if not set (warning logged).
# In production, set to a strong random value:
#   JWT_SECRET=$(openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-uuid

# ═══════════════════════════════════════════════════════════════════════════════
# TLS — Optional (use nginx/caddy reverse proxy in production)
# ═══════════════════════════════════════════════════════════════════════════════

# Direct TLS with built-in rustls server (optional — prefer reverse proxy).
# Paths to Let's Encrypt certificate and private key files.
# TLS_CERT_PATH=/etc/letsencrypt/live/benchify.example.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/benchify.example.com/privkey.pem

# ═══════════════════════════════════════════════════════════════════════════════
# SSO — Enterprise (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Master switch: enable SSO endpoints (OIDC, SAML, LDAP).
# Default: false (local auth only).
# SSO_ENABLED=true

# Base URL used for OIDC redirect URIs and SAML ACS URL construction.
# Must match the URL your IdP redirects to.
# SSO_REDIRECT_BASE_URL=https://benchify.example.com

# ── OIDC Providers (config file) ──
# Configure OIDC providers via environment (optional — DB configs take precedence).
# Each provider needs: name, client_id, client_secret, issuer_url, scopes.

# Example: Google Workspace OIDC
# OIDC_PROVIDERS__0__NAME=google
# OIDC_PROVIDERS__0__CLIENT_ID=your-client-id.apps.googleusercontent.com
# OIDC_PROVIDERS__0__CLIENT_SECRET=your-client-secret
# OIDC_PROVIDERS__0__ISSUER_URL=https://accounts.google.com
# OIDC_PROVIDERS__0__SCOPES__0=openid
# OIDC_PROVIDERS__0__SCOPES__1=profile
# OIDC_PROVIDERS__0__SCOPES__2=email
# OIDC_PROVIDERS__0__ATTRIBUTE_MAPPING__EMAIL=email
# OIDC_PROVIDERS__0__ATTRIBUTE_MAPPING__DISPLAY_NAME=name

# Example: Okta OIDC
# OIDC_PROVIDERS__1__NAME=okta
# OIDC_PROVIDERS__1__CLIENT_ID=your-okta-client-id
# OIDC_PROVIDERS__1__CLIENT_SECRET=your-okta-client-secret
# OIDC_PROVIDERS__1__ISSUER_URL=https://your-domain.okta.com
# OIDC_PROVIDERS__1__SCOPES__0=openid
# OIDC_PROVIDERS__1__SCOPES__1=profile
# OIDC_PROVIDERS__1__SCOPES__2=email

# ═══════════════════════════════════════════════════════════════════════════════
# JIRA INTEGRATION — Enterprise (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Master switch: enable Jira issue creation from session detail page.
# Default: false.
# JIRA_ENABLED=true

# Jira Cloud base URL (e.g., "https://your-domain.atlassian.net").
# JIRA_BASE_URL=https://your-domain.atlassian.net

# Jira account email for Basic authentication.
# JIRA_EMAIL=your-email@example.com

# Jira API token (NOT your account password).
# Generate at: https://id.atlassian.com/manage/api-tokens
# JIRA_API_TOKEN=your-api-token

# ═══════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS — Email (SMTP) — Optional
# ═══════════════════════════════════════════════════════════════════════════════

# SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net).
# SMTP_HOST=smtp.example.com

# SMTP port (587 for TLS, 465 for SSL, 25 for unencrypted).
# SMTP_PORT=587

# SMTP authentication username.
# SMTP_USERNAME=your-smtp-username

# SMTP authentication password or app-specific password.
# SMTP_PASSWORD=your-smtp-password

# From email address for outgoing notifications.
# SMTP_FROM_EMAIL=benchify@example.com

# ═══════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS — Slack Webhook — Optional
# ═══════════════════════════════════════════════════════════════════════════════

# Slack incoming webhook URL for alert notifications.
# Create at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
