<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- The Flutter UI ships only a dark theme today (B-070). The Android
         splash + window background must match or the user sees a brief
         white flash before Flutter renders. Use Black.NoTitleBar to keep
         the perceived brand consistent. The dark `values-night/styles.xml`
         already used Black.NoTitleBar; this aligns the day variant. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
